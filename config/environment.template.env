# AnchorAlpha Environment Variables Template
# Copy this file to .env and fill in your actual values
# This file is used for local development and testing

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Financial Modeling Prep API
# Get your API key from: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Perplexity Sonar API
# Get your API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# =============================================================================
# AWS CONFIGURATION
# =============================================================================

# AWS Region
AWS_REGION=us-east-1

# S3 Bucket for data storage (will be created by CloudFormation)
# Format: anchor-alpha-momentum-data-{environment}-{account-id}
S3_BUCKET=anchor-alpha-momentum-data-dev-123456789012

# AWS Account ID (for resource naming)
AWS_ACCOUNT_ID=123456789012

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# MARKET DATA CONFIGURATION
# =============================================================================

# Minimum market cap threshold (in USD)
MIN_MARKET_CAP=10000000000

# Number of top performers to select per tier
TOP_PERFORMERS_COUNT=20

# Momentum calculation windows (in days)
MOMENTUM_WINDOWS=7,30,60,90

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# FMP API rate limits (requests per minute)
FMP_REQUESTS_PER_MINUTE=300

# Perplexity API rate limits (requests per minute)
PERPLEXITY_REQUESTS_PER_MINUTE=60

# =============================================================================
# STREAMLIT CONFIGURATION (for local development)
# =============================================================================

# Streamlit server configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_SERVER_HEADLESS=false

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug mode for local development
DEBUG=true

# Mock API responses for testing (true/false)
USE_MOCK_DATA=false

# Cache duration for development (in seconds)
CACHE_TTL=3600